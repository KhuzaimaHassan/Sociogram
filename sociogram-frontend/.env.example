# Frontend (Vite) environment variables
# Copy to `.env` (or `.env.local`) and adjust as needed.

# Public URL of the Sociogram backend that the browser will call directly.
# Local dev:        http://localhost:3001
# Deployed:         https://sociogram-api.onrender.com
VITE_API_URL=http://localhost:3001

# Used ONLY by the Vite dev server proxy (so /api and /uploads work locally).
# If your backend lives elsewhere, point this at it.
VITE_BACKEND_PROXY=http://localhost:3001
