# Sociogram backend environment
# Copy to `.env` and fill in real values for your environment.

# PostgreSQL connection string. Examples:
#   Local:        postgresql://postgres:postgres@localhost:5432/sociogram?schema=public
#   Docker:       postgresql://postgres:postgres@db:5432/sociogram?schema=public
#   Neon (cloud): postgresql://USER:PASS@HOST/sociogram?sslmode=require
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/sociogram?schema=public"

# Generate strong random strings for production:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="change-me-to-a-long-random-string"
JWT_REFRESH_SECRET="change-me-to-a-different-long-random-string"

# Server port (defaults to 3001 if unset)
PORT=3001

# Origin allowed by CORS. Use the deployed frontend URL in production.
FRONTEND_URL="http://localhost:5173"

# Optional. Set to "production" in deployed environments.
NODE_ENV=development
